function hojeISO() { return new Date().toISOString().split("T")[0]; }
function gerarHoras() {
  const h: string[] = [];
  for (let i = 9; i <= 19; i++) {
    h.push(`${String(i).padStart(2,"0")}:00`);
    if (i < 19) h.push(`${String(i).padStart(2,"0")}:30`);
  }
  return h;
}
