  shell: {
    minHeight: "100vh",
    background: "#080808",
    display: "flex",
    flexDirection: "column",
  },
  nav: {
    display: "flex",
    alignItems: "center",
    gap: "0.75rem",
    padding: "0 1.5rem",
    height: "52px",
    borderBottom: "1px solid #161616",
    background: "#0a0a0a",
    position: "sticky",
    top: 0,
    zIndex: 50,
  },
  brand: {
    fontSize: "1rem",
    fontWeight: 700,
    color: GOLD,
    letterSpacing: "0.2em",
  },
  badge: {
    fontSize: "0.65rem",
    fontWeight: 600,
    color: GOLD,
    background: GOLD_BORDER,
    border: `1px solid ${GOLD_BORDER}`,
    borderRadius: "999px",
    padding: "2px 8px",
    letterSpacing: "0.1em",
    textTransform: "uppercase",
  },
  spacer: { flex: 1 },
  link: {
